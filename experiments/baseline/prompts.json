{
  "version": "2.0",
  "description": "Comprehensive experiment prompts for 75-resource dummy Terraform infrastructure. 30 prompts (8 easy, 10 medium, 12 hard) with ground truth answers for automated scoring. 2 trials per prompt. Covers attribute lookup, enumeration, dependency traversal, impact analysis, blast radius, cross-module chains, deployment ordering, and security filtering.",
  "infra_path": "./dummy-infra",
  "prompts": [
    {
      "id": 1,
      "prompt": "What is the CIDR block of the VPC?",
      "difficulty": "easy",
      "category": "attribute-lookup",
      "scoring": {
        "type": "substring-match",
        "ground_truth": {
          "substrings": ["10.0.0.0/16"]
        }
      }
    },
    {
      "id": 2,
      "prompt": "What is the public IP of the bastion host?",
      "difficulty": "easy",
      "category": "attribute-lookup",
      "scoring": {
        "type": "substring-match",
        "ground_truth": {
          "substrings": ["54.210.167.100"]
        }
      }
    },
    {
      "id": 3,
      "prompt": "What database engine and port does the RDS primary instance use?",
      "difficulty": "easy",
      "category": "attribute-lookup",
      "scoring": {
        "type": "substring-match",
        "ground_truth": {
          "substrings": ["postgresql", "5432"]
        }
      }
    },
    {
      "id": 4,
      "prompt": "List all six modules in the infrastructure.",
      "difficulty": "easy",
      "category": "enumeration",
      "scoring": {
        "type": "set-overlap",
        "ground_truth": {
          "expected": [
            "networking",
            "security",
            "compute",
            "database",
            "loadbalancer",
            "monitoring"
          ],
          "order_matters": false
        }
      }
    },
    {
      "id": 5,
      "prompt": "List all subnets and their availability zones.",
      "difficulty": "easy",
      "category": "enumeration",
      "scoring": {
