            "public_subnet_3 in us-east-1c",
            "private_subnet_1 in us-east-1a",
            "private_subnet_2 in us-east-1b",
            "private_subnet_3 in us-east-1c",
            "db_subnet_1 in us-east-1a",
            "db_subnet_2 in us-east-1b"
          ],
          "order_matters": false
        }
      }
    },
    {
      "id": 6,
      "prompt": "How many resources are there in total? Break down the count by module.",
      "difficulty": "easy",
      "category": "inventory",
      "scoring": {
        "type": "checklist",
        "ground_truth": {
          "items": [
            "75 total",
            "networking: 15",
            "security: 14",
            "compute: 16",
            "database: 10",
            "loadbalancer: 10",
            "monitoring: 10"
          ],
          "min_for_full": 7,
          "min_for_partial": 4
        }
      }
    },
    {
      "id": 7,
      "prompt": "What are the names of all four security groups?",
      "difficulty": "easy",
      "category": "enumeration",
      "scoring": {
        "type": "set-overlap",
        "ground_truth": {
          "expected": [
            "sg_alb",
            "sg_web",
            "sg_app",
            "sg_db"
          ],
          "order_matters": false
        }
      }
    },
    {
      "id": 8,
      "prompt": "What is the Redis cache engine version and node type?",
