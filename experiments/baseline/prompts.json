          "must_precede": [
            ["acm_certificate", "listener_https"],
            ["alb", "listener_http"],
            ["alb", "listener_https"],
            ["alb", "route53_record"],
            ["alb", "waf_web_acl"],
            ["listener_https", "listener_rule_web"],
            ["listener_https", "listener_rule_app"],
            ["target_group_web", "listener_https"],
            ["target_group_web", "listener_rule_web"],
            ["target_group_app", "listener_rule_app"]
          ]
        }
